#!/bin/bash

source common

# Count input arguments
if [[ "$#" -lt '2' ]]; then
	error "Additional arguments are required! \nUsage: ./build-setup <github username> <your email> (or vice-versa)"
else
	for arg in ${@}; do
		if [[ ${arg} =~ '@' ]]; then
			GIT_USER_MAIL=${arg}
		else
			GIT_USER_NAME=${arg}
		fi
	done
	if [[ -z ${GIT_USER_NAME} ]] || [[ -z ${GIT_USER_MAIL} ]]; then
		error "Improper arguments, either git email or username is missing"
	fi
fi

# Setup directory structure
mkdir -p ${MISC} \
		 ${ANDROID_PATH}

# Check whether we are running either Debian or Arch based distro
OS_BASE_DIST=$(cat /etc/*release | grep 'ID_LIKE=' | cut -f2 -d "=")
if [[ -z ${OS_BASE_DIST} ]]; then
	OS_BASE_DIST=$(cat /etc/*release | grep -m 1 'ID=' | cut -f2 -d "=")
fi

ARCH_PACKAGES=(
	aarch64-linux-gnu-gcc
	android-tools
	android-udev
	base-devel
	bison
	ccache
	clang
	cmake
	cpio
	curl
	git
	gperf
	flex
	gnupg
	jdk8-openjdk
	lib32-fakeroot
	lib32-gcc-libs
	lib32-libltdl
	lib32-ncurses
	lib32-readline
	lib32-zlib
	libxslt
	lld
	lzop
	make
	ncurses
	ninja
	perl-switch
	pngcrush
	python
	repo
	rsync
	schedtool
	sdl
	squashfs-tools
	unzip
	vim
	wxgtk2
	xclip
	zip
	zlib
)

DEBIAN_PACKAGES=(
	android-tools-adb
	android-tools-fastboot
	bison
	build-essential
	ccache
	clang
	flex
	fontconfig
	g++-multilib
	gcc-multilib
	gnupg
	imagemagick
	lib32ncurses-dev
	lib32z1-dev
	libc6-dev-i386
	libgl1-mesa-dev
	libx11-dev
	libxml2-utils
	openjdk-8-jdk
	python2
	rsync
	vim
	x11proto-core-dev
	xclip
	xsltproc
	zip
	zlib1g-dev
)

# Configure multilib, makepkg and update before installing our tools
if [[ 'arch' == ${OS_BASE_DIST} ]]; then
	warning "Configuring multilib"
	sudo sed -i "/\[multilib\]/,/Include/"'s/^#//' /etc/pacman.conf
	sudo sed -i "s/#MAKEFLAGS=\"-j2\"/MAKEFLAGS=\"-j$(nproc --all)\"/g" /etc/makepkg.conf
	sudo pacman -Syyu --noconfirm || error "Something went wrong while updating packages"
else
	sudo apt-get update && sudo apt-get dist-upgrade -y || error "Something went wrong while updating packages"
fi

# Install required packages
warning "Installing required packages and their dependencies"
if [[ 'arch' == ${OS_BASE_DIST} ]]; then
	sudo pacman -S --needed --noconfirm ${ARCH_PACKAGES[@]} || error "Error installing packages"
else
	sudo apt-get install -y ${DEBIAN_PACKAGES[@]} || error "Error installing packages"
fi

# Install AUR packages if on Arch
warning "Installing AUR packages"
if [[ 'arch' == ${OS_BASE_DIST} ]]; then
	yay -S --answerclean A --answerdiff N --needed lib32-ncurses5-compat-libs \
					rsync ncurses5-compat-libs \
					xml2 || error "Error installing AUR packages"
fi

# Cleanup
warning "Cleaning up"
if [[ 'arch' == ${OS_BASE_DIST} ]]; then
	sudo pacman -R --noconfirm $(pacman -Qdtq)
else
	sudo apt-get autoremove -y
fi

# Setup Git
git config --global user.name ${GIT_USER_NAME}
git config --global user.email ${GIT_USER_MAIL}
git config --global url.ssh://git@github.com/.insteadOf https://github.com/
git config --global core.excludesfile ~/.gitignore_global
git config --global core.editor vim

if [[ 'arch' != ${OS_BASE_DIST} ]]; then
	mkdir ~/bin
	PATH=~/bin:$PATH
	curl https://storage.googleapis.com/git-repo-downloads/repo > ~/bin/repo
	chmod a+x ~/bin/repo
fi

# Add my rules
{
	echo "# Personal exclusions #"
	echo "#######################"
	echo "out/"
	echo "*.ko"
	echo "Image.*"
	echo "zImage*"
	echo "dtbo*"
	echo "net/wireguard"
	echo "*.rej"
	echo ".DS_Store"
	echo ".DS_Store?"
	echo "*.log"
} >> ~/.gitignore_global

# Generate SSH keys
if [[ -f ~/.ssh/id_rsa.pub ]]; then
	warning "Copying your existing SSH key..."
	xclip -sel clip < ~/.ssh/id_rsa.pub
else
	warning "Generating a new SSH key"
	ssh-keygen -t rsa -b 4096 -C "${GIT_USER_MAIL}" -P "" -f ~/.ssh/id_rsa -q
	eval "$(ssh-agent -s)"
	ssh-add ~/.ssh/id_rsa
	xclip -sel clip < ~/.ssh/id_rsa.pub
fi

warning "Restoring the .bashrc profile"
{
	echo ""
	cat dotfiles/bashrc
} >> ~/.bashrc

warning "Now go to your GitHub account and follow these steps: \n1) Settings \n2) SSH and GPG keys \n3) New SSH key \n4) Click on the 'Key' field and press CTRL+V \n5) Click on 'Add SSH key'"
sleep 10
warning "The setup is done, please reboot your computer before compiling AOSP first"
